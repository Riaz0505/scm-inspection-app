{
  "entities": {
    "Report": {
      "title": "Inspection Report",
      "description": "A report of defects found on a garment style",
      "type": "object",
      "properties": {
        "styleId": { "type": "string" },
        "styleName": { "type": "string" },
        "layoutImage": { "type": "string" },
        "reporterEmail": { "type": "string" },
        "reporterUid": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "flagged"] },
        "defects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "subCategory": { "type": "string" },
              "part": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["styleId", "defects", "createdAt"]
    },
    "Style": {
      "title": "Garment Style",
      "description": "A style template for garments",
      "type": "object",
      "properties": {
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "modelId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "layoutImage": { "type": "string" },
        "customPoints": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["barcode", "name"]
    },
    "Category": {
      "title": "Defect Category",
      "description": "A category of possible defects",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "subCategories": { "type": "array" }
      }
    },
    "GarmentModel": {
      "title": "Garment Model",
      "description": "A template for a garment type with predefined marker points",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "frontImageUrl": { "type": "string" },
        "backImageUrl": { "type": "string" },
        "customPoints": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["name", "type"]
    }
  },
  "firestore": {
    "/reports": {
      "schema": "Report",
      "description": "Collection of all inspection reports"
    },
    "/styles": {
      "schema": "Style",
      "description": "Collection of available styles"
    },
    "/categories": {
      "schema": "Category",
      "description": "Defect categories master data"
    },
    "/models": {
      "schema": "GarmentModel",
      "description": "Garment model templates"
    }
  }
}
